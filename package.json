{
  "name": "agent-board",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Local-first kanban board for coordinating human and AI project work.",
  "homepage": "https://github.com/Th3Sp00kyM8/agent-board#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Th3Sp00kyM8/agent-board.git"
  },
  "bugs": {
    "url": "https://github.com/Th3Sp00kyM8/agent-board/issues"
  },
  "keywords": [
    "kanban",
    "local-first",
    "project-management",
    "ai-workflow",
    "planning"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently --kill-others -n server,vite -c blue,green \"node server.js\" \"vite\"",
    "server": "node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "reset:sample": "node scripts/reset-local-data.js",
    "verify": "node scripts/verify.js",
    "release:check": "npm run verify && npm run build && npm audit --audit-level=moderate",
    "smoke:fresh": "node scripts/smoke-fresh-copy.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^8.1.0"
  }
}
